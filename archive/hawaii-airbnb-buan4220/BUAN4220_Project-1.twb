      <aliases enabled='yes' />
      <column caption='Price Tiers' datatype='string' name='[Calculation_1099441275337854976]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([price]) &lt; 214 THEN &quot;Very Low&quot;&#13;&#10;ELSEIF AVG([price]) &lt; 281 THEN &quot;Low&quot;&#13;&#10;ELSEIF AVG([price]) &lt; 348 THEN &quot;Mid&quot;&#13;&#10;ELSEIF AVG([price]) &lt; 415 THEN &quot;High&quot;&#13;&#10;ELSE &quot;Very High&quot;&#13;&#10;END' />
      </column>
      <column caption='Total Listings' datatype='string' name='[Calculation_1213438641735667712]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Total Listings&quot;' />
      </column>
      <column caption='Average Airbnb Price' datatype='string' name='[Calculation_1213438641736429569]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Avg Airbnb Price&quot;' />
      </column>
      <column caption='Average Review Score' datatype='string' name='[Calculation_1213438641738616834]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Avg Rating&quot;' />
      </column>
      <column aggregation='Sum' caption='Avg Hotel Price' datatype='integer' datatype-customized='true' name='[Calculation_1213438641739587587]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='250' />
      </column>
      <column caption='Total Neighboorhoods' datatype='string' name='[Calculation_1213438641747062788]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Total Neighboorhoods&quot;' />
      </column>
      <column caption='All Island Average' datatype='real' name='[Calculation_1597933459531501568]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : AVG([price]) }' />
      </column>
      <column caption='Top 5 filter' datatype='string' name='[Calculation_1597933459553144836]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF INDEX() &lt;= 5 THEN &quot;Show&quot; ELSE &quot;Hide&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Listings by Island' datatype='string' name='[Calculation_855683946646007812]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Listings by&#13;&#10;   Island&quot;' />
      </column>
      <column caption='Room Type %' datatype='string' name='[Calculation_855683946649550855]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Room Type&quot;' />
      </column>
      <column aggregation='Sum' caption='Hotels' datatype='integer' name='[Calculation_855683946653380616]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='400' />
      </column>
      <column caption='Title' datatype='string' name='[Calculation_855683946659590153]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Airbnb &amp; Hotel&#13;&#10;Analysis in Hawaii&quot;' />
      </column>
      <column aggregation='CountD' caption='Cheaper than Hotel?' datatype='string' name='[Calculation_855683946688012305]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [area] : AVG([price]) } &lt; 250 THEN &quot;Cheaper&quot;&#13;&#10;ELSE &quot;More Expensive&quot;&#13;&#10;END' />
      </column>
      <column caption='hawaii_data' datatype='table' name='[__tableau_internal_object_id__].[hawaii!data_40385224C08B489885AD55726A6A56B0]' role='measure' type='quantitative' />
