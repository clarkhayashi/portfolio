---
import Base from "../layouts/Base.astro";
import ButtonLink from "../components/ButtonLink.astro";
import StatusLabel from "../components/StatusLabel.astro";
import { projects } from "../data/projects";

const proofStats = [
  { value: "~36K", label: "Hawai‘i lodging listings analyzed" },
  { value: "7 years", label: "Participation data translated for UREC" },
  { value: "$22.5K", label: "Won across two business plan competitions" },
];

const getProject = (title: string) => {
  const project = projects.find((item) => item.title === title);
  if (!project) throw new Error(`Project not found: ${title}`);
  return project;
};

const featuredProjects = [
  getProject("Finding the Best Value Stays in Hawai'i"),
  getProject("Intramural Sports Participation Analysis"),
];

const buildingProject = getProject("Real Estate Lead Analytics");
---

<Base
  title="Clark Hayashi · Business & Marketing Analyst"
  description="Business and marketing analyst turning messy data into clear decisions through analytics, marketing measurement, dashboards, and AI-enabled workflows."
>
  <section class="mx-auto max-w-[1000px] px-6 pb-10 pt-3 md:pb-14 md:pt-8">
    <div class="grid items-center gap-8 md:grid-cols-[1fr_auto] md:gap-12">
      <div>
        <p class="mb-3 text-xs font-medium uppercase tracking-[0.16em] text-teal-deep">
          Business + Marketing Analyst · AI-enabled
        </p>
        <h1
          class="max-w-[20ch] font-serif text-[2.55rem] font-bold leading-[1.04] tracking-tight md:text-[3.65rem]"
        >
          I turn messy data into decisions teams can use.
        </h1>
        <p class="mt-5 max-w-[58ch] text-lg leading-relaxed text-ink/70">
          I connect analytics, marketing measurement, and practical operations
          to build dashboards, systems, and recommendations that make the next
          move clearer.
        </p>
        <p class="mt-2 text-sm text-bark">
          Hawai‘i-raised · Seattle-based · Seattle University graduate
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <ButtonLink href="#featured-work">See selected work</ButtonLink>
          <ButtonLink href="/resume.pdf" variant="ghost">Resume</ButtonLink>
        </div>
        <p class="mt-4 flex flex-wrap gap-x-5 gap-y-2 text-sm text-ink/65">
          <a
            href="https://www.linkedin.com/in/clark-hayashi"
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-teal-deep">LinkedIn ↗</a
          >
          <a href="mailto:hayashiclark@gmail.com" class="transition-colors hover:text-teal-deep">
            Email
          </a>
        </p>
      </div>
      <img
        src="/headshot.jpg"
        alt="Clark Hayashi"
        width="240"
        height="240"
        class="order-first h-32 w-32 rounded-2xl object-cover md:order-none md:h-60 md:w-60"
      />
    </div>
  </section>

  <section aria-label="Selected proof" class="border-y border-ink/10">
    <div
      class="mx-auto grid max-w-[1000px] divide-y divide-ink/10 px-6 sm:grid-cols-3 sm:divide-x sm:divide-y-0"
    >
      {
        proofStats.map((item) => (
          <div class="py-4 sm:px-5 sm:py-5 sm:first:pl-0 sm:last:pr-0">
            <p class="font-serif text-2xl font-bold leading-none text-bark">{item.value}</p>
            <p class="mt-1.5 text-sm leading-snug text-ink/65">{item.label}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section id="featured-work" class="mx-auto max-w-[1000px] px-6 pt-14 md:pt-20">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.16em] text-teal-deep">
          Proof before promises
        </p>
        <h2 class="mt-2 font-serif text-3xl font-bold tracking-tight md:text-4xl">
          Selected Work
        </h2>
      </div>
      <a href="/work" class="text-sm font-medium text-teal-deep transition-colors hover:text-ink">
        Explore all work →
      </a>
    </div>

    <div class="mt-7 grid gap-5 md:grid-cols-2">
      {
        featuredProjects.map((project) => (
          <a
            href={project.href || "/work"}
            target={project.external ? "_blank" : undefined}
            rel={project.external ? "noopener noreferrer" : undefined}
            class="group flex h-full flex-col rounded-2xl border border-ink/10 p-6 transition hover:-translate-y-0.5 hover:border-teal/60 md:p-7"
          >
            <div class="flex items-start justify-between gap-4">
              <p class="text-xs font-medium uppercase tracking-[0.14em] text-bark">
                {project.lane}
              </p>
              <span class="text-teal transition-transform group-hover:translate-x-0.5" aria-hidden="true">
                {project.external ? "↗" : "→"}
              </span>
            </div>
            <h3 class="mt-3 font-serif text-2xl font-bold leading-tight tracking-tight">
              {project.title}
            </h3>
            <p class="mt-3 leading-relaxed text-ink/70">{project.description}</p>
            <div class="mt-auto pt-6">
              {project.proof && <p class="mb-3 text-sm font-medium text-bark">{project.proof}</p>}
              <StatusLabel label={project.statusLabel} type={project.statusType} />
            </div>
          </a>
        ))
      }
    </div>

    <a
      href={buildingProject.href || "/work"}
      class="group mt-5 flex flex-col gap-3 rounded-2xl border border-ink/10 px-5 py-5 transition hover:border-teal/60 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.14em] text-bark">Building now</p>
        <h3 class="mt-1 font-serif text-xl font-bold tracking-tight">{buildingProject.title}</h3>
        <p class="mt-1 text-sm text-ink/65">
          GA4, Tag Manager, Search Console, UTM strategy, and local SEO measurement.
        </p>
      </div>
      <span class="text-sm font-medium text-teal-deep">Follow the build →</span>
    </a>
  </section>

  <section class="mx-auto max-w-[1000px] px-6 pt-14 md:pt-20">
    <div class="rounded-2xl bg-ink px-7 py-8 text-paper md:flex md:items-center md:justify-between md:gap-10 md:px-10 md:py-10">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.16em] text-paper/60">
          Open to analyst roles
        </p>
        <h2 class="mt-2 max-w-[23ch] font-serif text-2xl font-bold tracking-tight md:text-3xl">
          Need someone who can connect data, people, and execution?
        </h2>
      </div>
      <div class="mt-6 flex shrink-0 flex-wrap gap-3 md:mt-0">
        <a
          href="mailto:hayashiclark@gmail.com"
          class="inline-flex items-center rounded-full bg-paper px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-teal hover:text-paper"
        >
          Email Clark
        </a>
        <a
          href="https://www.linkedin.com/in/clark-hayashi"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-paper/30 px-5 py-2.5 text-sm font-medium text-paper transition-colors hover:border-paper"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</Base>
