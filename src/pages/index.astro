---
import Base from "../layouts/Base.astro";
import ButtonLink from "../components/ButtonLink.astro";
import WorkList from "../components/WorkList.astro";
import LaneList from "../components/LaneList.astro";
import WaveDivider from "../components/WaveDivider.astro";

const identity = [
  "Business Analytics + Marketing",
  "Marketing Measurement",
  "AI Strategy",
  "Operations",
  "Visual Communication",
  "Seattle / Hawai‘i / Japan",
];

/* How I Work: Analyze → Translate → Build */
const framework = [
  {
    title: "Analyze",
    body: "Start with the decision someone actually needs to make, then dig into the messy data, workflows, and business questions behind it. If the output doesn't change a decision, it isn't done.",
  },
  {
    title: "Translate",
    body: "Turn findings into clear stories: dashboards, decks, and recommendations in plain language. Data explains what's happening; talking to people explains why.",
  },
  {
    title: "Build",
    body: "Ship practical systems, reporting, and workflows teams actually use. A dashboard a team opens twice a week beats a perfect model nobody touches.",
  },
];
---

<Base>
  <!-- Hero -->
  <section class="mx-auto max-w-[1000px] px-6 pb-14 pt-4 md:pb-20 md:pt-10">
    <div class="grid items-center gap-10 md:grid-cols-[1fr_auto]">
      <div>
        <p class="mb-4 text-xs font-medium uppercase tracking-[0.16em] text-teal-deep">
          Business / Marketing Analyst · Measurement · Dashboards · AI Workflows
        </p>
        <h1
          class="max-w-[22ch] font-serif text-[2.6rem] font-bold leading-[1.06] tracking-tight md:text-[3.5rem]"
        >
          I turn <em class="italic">messy</em> data, ideas, and operations into clear decisions.
        </h1>
        <p class="mt-6 max-w-[56ch] text-lg leading-relaxed text-ink/70">
          Business Analytics &amp; Marketing graduate from Seattle University.
          Recent work: AI use-case prioritization at Bank of Hawaii,
          participation dashboards for Seattle U Recreation, and GA4/SEO lead
          tracking for a real estate business.
        </p>
        <p class="mt-3 text-sm text-bark">
          Rooted in Hawai‘i. Built in Seattle. Expanded through Tokyo and Italy.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <ButtonLink href="/work">View Work</ButtonLink>
          <ButtonLink href="/resume.pdf" variant="ghost">Resume</ButtonLink>
          <ButtonLink
            href="https://www.linkedin.com/in/clark-hayashi"
            variant="ghost"
            external>LinkedIn</ButtonLink
          >
          <ButtonLink href="mailto:hayashiclark@gmail.com" variant="ghost"
            >Email</ButtonLink
          >
        </div>
      </div>
      <img
        src="/headshot.jpg"
        alt="Clark Hayashi"
        width="288"
        height="288"
        class="order-first h-48 w-48 rounded-2xl object-cover md:order-none md:h-72 md:w-72"
      />
    </div>
  </section>

  <!-- Identity / credibility strip -->
  <section class="border-y border-ink/10">
    <ul
      class="mx-auto flex max-w-[1000px] flex-wrap justify-center gap-x-3 gap-y-2 px-6 py-5 text-xs font-medium uppercase tracking-[0.14em] text-ink/65"
    >
      {
        identity.map((item, i) => (
          <li class="flex items-center gap-3">
            {i > 0 && (
              <span class="text-teal/60" aria-hidden="true">
                ·
              </span>
            )}
            {item}
          </li>
        ))
      }
    </ul>
  </section>

  <!-- What I Bring -->
  <section class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
      What I Bring
    </h2>
    <p class="mb-8 mt-3 max-w-[58ch] text-ink/70">
      Five lanes, one job: make things clearer.
    </p>
    <LaneList />
  </section>

  <!-- Selected Work -->
  <section class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
      Selected Work
    </h2>
    <p class="mb-10 mt-3 max-w-[58ch] text-ink/70">
      Completed work leads. Anything unfinished says so.
    </p>
    <WorkList />
  </section>

  <WaveDivider />

  <!-- How I Work -->
  <section class="mx-auto max-w-[1000px] px-6 pt-12 md:pt-16">
    <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
      How I Work
    </h2>
    <div class="mt-8 grid gap-8 md:grid-cols-3 md:gap-10">
      {
        framework.map((step, i) => (
          <div>
            <p class="text-sm font-medium text-bark/60">0{i + 1}</p>
            <h3 class="mt-1 font-serif text-[1.35rem] font-bold">{step.title}</h3>
            <p class="mt-2 leading-relaxed text-ink/70">{step.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- About / Rooted Perspective teaser -->
  <section class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <div class="border-t border-ink/10 pt-12">
      <p class="max-w-[58ch] text-lg leading-relaxed text-ink/75">
        Before this, I was one of Bank of Hawaii's first AI interns and
        co-founded a student credit union initiative that won $22.5K across
        two business plan competitions. The thread through all of it: helping
        teams make sense of messy problems and turn ideas into action.
      </p>
      <a
        href="/about"
        class="mt-4 inline-block font-medium text-teal-deep transition-colors hover:text-ink"
        >More about me →</a
      >
    </div>
  </section>

  <!-- Contact strip -->
  <section class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <div class="rounded-2xl bg-ink px-8 py-10 text-paper md:px-12 md:py-14">
      <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
        Open to analyst roles across business, data, and marketing.
      </h2>
      <p class="mt-3 max-w-[52ch] text-paper/70">
        If your team needs someone who can take a messy problem and hand back
        a clear decision, let's talk.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href="mailto:hayashiclark@gmail.com"
          class="inline-flex items-center rounded-full bg-paper px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-teal-deep hover:text-paper"
          >hayashiclark@gmail.com</a
        >
        <a
          href="https://www.linkedin.com/in/clark-hayashi"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-paper/30 px-5 py-2.5 text-sm font-medium text-paper transition-colors hover:border-teal hover:text-paper"
          >LinkedIn</a
        >
      </div>
    </div>
  </section>
</Base>
