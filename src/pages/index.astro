---
import Base from "../layouts/Base.astro";
import ButtonLink from "../components/ButtonLink.astro";
import WorkList from "../components/WorkList.astro";
import LaneList from "../components/LaneList.astro";
import WaveDivider from "../components/WaveDivider.astro";
import JourneyStepper from "../components/JourneyStepper.astro";

/* How I Work: Analyze → Translate → Build */
const framework = [
  {
    title: "Analyze",
    body: "Start with the decision someone actually needs to make, then dig into the messy data, workflows, and business questions behind it. If the output doesn't change a decision, it isn't done.",
  },
  {
    title: "Translate",
    body: "Turn findings into clear stories: dashboards, decks, and recommendations in plain language. Data explains what's happening; talking to people explains why.",
  },
  {
    title: "Build",
    body: "Ship practical systems, reporting, and workflows teams actually use. A dashboard a team opens twice a week beats a perfect model nobody touches.",
  },
];
---

<Base>
  <!-- Hero -->
  <section class="mx-auto max-w-[1000px] px-6 pb-12 pt-4 md:pb-14 md:pt-8">
    <div class="grid items-center gap-10 md:grid-cols-[1fr_auto]">
      <div>
        <p class="mb-4 text-xs font-medium uppercase tracking-[0.16em] text-teal-deep">
          Business + Marketing Analyst
        </p>
        <h1
          class="max-w-[22ch] font-serif text-[2.6rem] font-bold leading-[1.06] tracking-tight md:text-[3.5rem]"
        >
          I turn <em class="italic">messy</em> data, ideas, and operations into clear decisions.
        </h1>
        <p class="mt-6 max-w-[52ch] text-lg leading-relaxed text-ink/75">
          I like taking scattered information, finding the pattern, and
          explaining what matters in plain language. I use analysis, dashboards,
          and practical AI tools to get there.
        </p>
        <p class="mt-3 text-sm text-bark">
          Rooted in Hawai‘i. Built in Seattle. Expanded through Tokyo and Italy.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <ButtonLink href="/work" size="large">View Work</ButtonLink>
          <ButtonLink href="/resume.pdf" variant="ghost" size="large">Resume</ButtonLink>
        </div>
      </div>
      <div class="order-first flex flex-col items-center md:order-none">
        <img
          src="/headshot.jpg"
          alt="Clark Hayashi"
          width="288"
          height="288"
          class="h-48 w-48 rounded-2xl object-cover md:h-72 md:w-72"
        />
        <div class="mt-4 flex items-center gap-3">
          <a
            href="https://www.linkedin.com/in/clark-hayashi"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Clark Hayashi on LinkedIn"
            title="LinkedIn"
            class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-ink/15 bg-white/60 text-[#0A66C2] shadow-sm transition-all hover:-translate-y-0.5 hover:border-[#0A66C2] hover:bg-[#0A66C2] hover:text-white"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="currentColor">
              <path d="M5.34 3.5A1.84 1.84 0 1 1 5.34 7.18 1.84 1.84 0 0 1 5.34 3.5ZM3.75 8.56h3.18V20H3.75V8.56Zm5.16 0h3.05v1.56H12c.43-.81 1.47-1.98 3.61-1.98 3.87 0 4.58 2.55 4.58 5.86v6h-3.18v-5.32c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.81V20H8.91V8.56Z"/>
            </svg>
          </a>
          <a
            href="https://github.com/clarkhayashi"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Clark Hayashi on GitHub"
            title="GitHub"
            class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-ink/15 bg-white/60 text-ink shadow-sm transition-all hover:-translate-y-0.5 hover:border-ink hover:bg-ink hover:text-paper"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="currentColor">
              <path d="M12 .7a11.5 11.5 0 0 0-3.64 22.41c.58.11.79-.25.79-.56v-2.24c-3.22.7-3.9-1.37-3.9-1.37-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.71.08-.71 1.16.08 1.78 1.2 1.78 1.2 1.04 1.77 2.71 1.26 3.38.96.1-.75.4-1.26.74-1.55-2.57-.29-5.27-1.29-5.27-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.16 1.18a10.95 10.95 0 0 1 5.75 0c2.19-1.49 3.16-1.18 3.16-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.4-2.71 5.38-5.29 5.67.42.36.79 1.07.79 2.16v3.2c0 .31.21.68.8.56A11.5 11.5 0 0 0 12 .7Z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <JourneyStepper />

  <!-- Selected Work -->
  <section id="selected-work" class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
      Selected Work
    </h2>
    <p class="mb-10 mt-3 max-w-[58ch] text-ink/70">
      Completed work leads. Anything unfinished says so.
    </p>
    <WorkList />
  </section>

  <!-- What I Bring -->
  <section class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">What I Bring</h2>
    <p class="mb-8 mt-3 max-w-[58ch] text-ink/70">Five lanes, one job: make things clearer. The work above is the evidence.</p>
    <LaneList />
  </section>

  <WaveDivider />

  <!-- How I Work -->
  <section class="mx-auto max-w-[1000px] px-6 pt-12 md:pt-16">
    <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
      How I Work
    </h2>
    <div class="mt-8 grid gap-8 md:grid-cols-3 md:gap-10">
      {
        framework.map((step, i) => (
          <div>
            <p class="text-sm font-medium text-bark/60">0{i + 1}</p>
            <h3 class="mt-1 font-serif text-[1.35rem] font-bold">{step.title}</h3>
            <p class="mt-2 leading-relaxed text-ink/70">{step.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- About / Rooted Perspective teaser -->
  <section class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <div class="border-t border-ink/10 pt-12">
      <p class="max-w-[58ch] text-lg leading-relaxed text-ink/75">
        I co-founded a student credit union initiative that won $22.5K across
        two business plan competitions and spent four years helping run Seattle
        U's intramural program. The thread through all of it: helping teams make
        sense of messy problems and turn ideas into action.
      </p>
      <a
        href="/about"
        class="mt-4 inline-block font-medium text-teal-deep transition-colors hover:text-ink"
        >More about me →</a
      >
    </div>
  </section>

  <!-- Contact strip -->
  <section class="mx-auto max-w-[1000px] px-6 pt-16 md:pt-24">
    <div class="rounded-2xl bg-ink px-8 py-10 text-paper md:px-12 md:py-14">
      <h2 class="font-serif text-3xl font-bold tracking-tight md:text-4xl">
        Open to analyst roles across business, data, and marketing.
      </h2>
      <p class="mt-3 max-w-[52ch] text-paper/70">
        If your team needs someone who can take a messy problem and hand back
        a clear decision, let's talk.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href="mailto:hayashiclark@gmail.com"
          class="inline-flex items-center rounded-full bg-paper px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-teal-deep hover:text-paper"
          >hayashiclark@gmail.com</a
        >
        <a
          href="https://www.linkedin.com/in/clark-hayashi"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-full border border-paper/30 px-5 py-2.5 text-sm font-medium text-paper transition-colors hover:border-teal hover:text-paper"
          >LinkedIn</a
        >
      </div>
    </div>
  </section>
</Base>
