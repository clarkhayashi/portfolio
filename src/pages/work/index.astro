---
import Base from "../../layouts/Base.astro";
import WorkList from "../../components/WorkList.astro";
---

<Base
  title="Work · Clark Hayashi"
  description="Public projects focused on turning real questions into decisions through pricing analysis, operational dashboards, marketing measurement, and data storytelling."
>
  <section class="mx-auto max-w-[1000px] px-6 pb-10 pt-10 md:pt-16">
    <h1 class="font-serif text-4xl font-semibold tracking-tight md:text-5xl">Work</h1>
    <p class="mb-10 mt-4 max-w-[58ch] leading-relaxed text-ink/70">
      Public projects focused on turning real questions into decisions. The
      statuses are honest: finished work leads, work in progress is labeled,
      and confidential employer work stays in Experience with approved public
      proof only.
    </p>
    <WorkList />
  </section>
</Base>
