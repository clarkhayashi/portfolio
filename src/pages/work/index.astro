---
import Base from "../../layouts/Base.astro";
import WorkList from "../../components/WorkList.astro";
---

<Base
  title="Work · Clark Hayashi"
  description="Analytics projects focused on turning real questions into decisions: pricing analysis, operational dashboards, lead tracking, and enterprise AI prioritization."
>
  <section class="mx-auto max-w-[1000px] px-6 pb-10 pt-10 md:pt-16">
    <h1 class="font-serif text-4xl font-semibold tracking-tight md:text-5xl">Work</h1>
    <p class="mb-10 mt-4 max-w-[58ch] leading-relaxed text-ink/70">
      Analytics projects focused on turning real questions into decisions. The
      statuses are honest: case studies are published in public-safe form as
      results land, and confidential work stays summarized.
    </p>
    <WorkList />
  </section>
</Base>
