---
import Base from "../layouts/Base.astro";

const quests = [
  {
    eyebrow: "Reading",
    title: "Reading Notes",
    description:
      "Books, essays, and ideas I wanted to keep—not summaries written for a grade.",
    href: "https://clarkhayashi.github.io/my-websites/clark-reading-notes/",
    action: "Open the notebook ↗",
    className: "bg-[#111C29] text-[#F7F1E7] md:col-span-7",
    muted: "text-[#F7F1E7]/65",
  },
  {
    eyebrow: "Small builds",
    title: "Experiments",
    description:
      "Code, prototypes, and side projects that are useful, interesting, or simply worth trying.",
    href: "https://github.com/clarkhayashi",
    action: "Browse GitHub ↗",
    className: "border border-ink/10 bg-white/55 text-ink md:col-span-5",
    muted: "text-ink/65",
  },
];
---

<Base
  title="Side Quests · Clark Hayashi"
  description="Clark Hayashi's reading notes, small experiments, and other curiosity-driven projects."
>
  <section class="mx-auto max-w-[1000px] px-6 pb-8 pt-10 md:pt-16">
    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-teal-deep">
      Off the clock, still curious
    </p>
    <h1 class="mt-3 font-serif text-4xl font-bold tracking-tight md:text-6xl">
      Side Quests
    </h1>
    <p class="mt-5 max-w-[54ch] text-lg leading-relaxed text-ink/70">
      Books, notes, small builds, and the things I follow because they make me
      curious—not because they fit neatly inside a job title.
    </p>
  </section>

  <section class="mx-auto max-w-[1000px] px-6 pb-8">
    <div class="grid gap-5 md:grid-cols-12">
      {
        quests.map((quest) => (
          <a
            href={quest.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "group flex min-h-[260px] flex-col justify-between rounded-[1.5rem] p-7 shadow-sm transition-transform hover:-translate-y-1 md:p-9",
              quest.className,
            ]}
          >
            <div>
              <p class:list={["text-xs font-semibold uppercase tracking-[0.15em]", quest.muted]}>
                {quest.eyebrow}
              </p>
              <h2 class="mt-3 font-serif text-3xl font-bold tracking-tight md:text-4xl">
                {quest.title}
              </h2>
              <p class:list={["mt-4 max-w-[38ch] leading-relaxed", quest.muted]}>
                {quest.description}
              </p>
            </div>
            <span class="mt-10 font-semibold">{quest.action}</span>
          </a>
        ))
      }

      <div class="rounded-[1.5rem] border border-ink/10 bg-teal/10 p-7 md:col-span-12 md:p-9">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-teal-deep">
          On deck
        </p>
        <p class="mt-3 max-w-[60ch] font-serif text-2xl font-bold leading-snug tracking-tight md:text-3xl">
          Japanese study notes, travel and photo field notes, and the occasional
          basketball rabbit hole.
        </p>
        <p class="mt-4 text-sm text-ink/60">
          I’ll add them when there is something real worth sharing.
        </p>
      </div>
    </div>
  </section>
</Base>
