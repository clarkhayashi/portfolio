---
import Base from "../layouts/Base.astro";
---

<Base
  title="Side Quests · Clark Hayashi"
  description="Clark Hayashi's reading notes, Japanese learning, movement, and small experiments."
>
  <main class="quests-shell">
    <section class="quests-intro" aria-labelledby="side-quests-title">
      <h1 id="side-quests-title">Side Quests</h1>
      <p class="intro-copy">
        The things I keep learning, making, and following when nobody assigned
        them to me
      </p>
    </section>

    <section class="quest-grid" aria-label="Clark's side quests">
      <a
        class="quest-card duo-card"
        href="https://www.duolingo.com/profile/ClarkHayashi"
        target="_blank"
        rel="noopener noreferrer"
        data-tooltip="I’m learning Japanese 🇯🇵 · Follow me on Duolingo"
      >
        <span class="external-mark" aria-hidden="true">↗</span>

        <div class="duo-copy">
          <p class="duo-streak">
            <span id="duo-streak-number">—</span>
            <span id="duo-streak-label">public profile</span>
          </p>
          <h2>My Duolingo</h2>
        </div>

        <div class="duo-meta" aria-live="polite">
          <span id="duo-course">Japanese</span>
          <span aria-hidden="true">·</span>
          <span id="duo-xp">Live stats when available</span>
        </div>

        <img
          class="duo-avatar"
          src="/duolingo-clark.svg"
          alt="Clark's Duolingo avatar"
          width="670"
          height="563"
        />
      </a>

      <a
        class="quest-card notes-card"
        href="https://clarkhayashi.github.io/my-websites/clark-reading-notes/"
        target="_blank"
        rel="noopener noreferrer"
        data-tooltip="What I’m listening to becomes what I’m thinking about"
      >
        <span class="external-mark" aria-hidden="true">↗</span>

        <img
          class="audible-logo"
          src="/audible-logo.svg"
          alt="Audible"
          width="1920"
          height="547"
        />

        <div class="notes-copy">
          <h2>Reading Notes</h2>
          <p>Books and ideas worth keeping, connected in my own words</p>
        </div>

        <span class="card-action">Open my notes ↗</span>
      </a>

      <article
        class="quest-card strava-card"
        data-tooltip="Your Lunch Hike · Open the live activity on Strava"
      >
        <div class="strava-embed-shell">
          <div
            class="strava-embed-placeholder"
            data-embed-type="activity"
            data-embed-id="19068024693"
            data-style="standard"
            data-from-embed="false"
            data-token="-vrpW4WL_5ZYnKOmhaa9H965qt9_m3zvr0zWO2qcltU"
          ></div>
        </div>

        <div class="strava-overlay">
          <a
            href="https://www.strava.com/activities/19068024693"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open Lunch Hike on Strava ↗
          </a>
        </div>
      </article>

      <a
        class="quest-card github-card"
        href="https://github.com/clarkhayashi"
        target="_blank"
        rel="noopener noreferrer"
        data-tooltip="Small builds, experiments, and code I wanted to understand"
      >
        <span class="external-mark" aria-hidden="true">↗</span>

        <div class="code-window" aria-hidden="true">
          <div class="code-dots"><i></i><i></i><i></i></div>
          <span class="code-line line-one"></span>
          <span class="code-line line-two"></span>
          <span class="code-line line-three"></span>
          <span class="code-line line-four"></span>
        </div>

        <div class="github-copy">
          <h2>Build to learn</h2>
          <p>Prototypes, useful tools, and rabbit holes with a commit history</p>
        </div>

        <span class="card-action">Browse GitHub ↗</span>
      </a>
    </section>
  </main>

  <div id="quest-tooltip" role="tooltip" aria-hidden="true"></div>
</Base>

<script is:inline async src="https://strava-embeds.com/embed.js"></script>

<script>
  const compactNumber = new Intl.NumberFormat("en-US", {
    notation: "compact",
    maximumFractionDigits: 1,
  });

  const streakNumber = document.querySelector("#duo-streak-number");
  const streakLabel = document.querySelector("#duo-streak-label");
  const courseName = document.querySelector("#duo-course");
  const courseXp = document.querySelector("#duo-xp");

  fetch("/api/duolingo")
    .then((response) => {
      if (!response.ok) throw new Error("Profile unavailable");
      return response.json();
    })
    .then((profile) => {
      if (streakNumber && Number.isFinite(profile.streak)) {
        streakNumber.textContent = String(profile.streak);
        streakLabel.textContent = "day streak";
      }

      if (courseName && profile.course?.title) {
        courseName.textContent = profile.course.title;
      }

      const xp = profile.course?.xp ?? profile.totalXp;
      if (courseXp && Number.isFinite(xp)) {
        courseXp.textContent = `${compactNumber.format(xp)} XP`;
      }
    })
    .catch(() => {
      // The public profile link remains the intentional fallback.
    });

  const tooltip = document.querySelector("#quest-tooltip");
  const finePointer = window.matchMedia(
    "(pointer: fine) and (min-width: 769px)",
  );

  if (tooltip && finePointer.matches) {
    document.querySelectorAll("[data-tooltip]").forEach((card) => {
      card.addEventListener("pointerenter", () => {
        tooltip.textContent = card.getAttribute("data-tooltip") ?? "";
        tooltip.setAttribute("aria-hidden", "false");
        tooltip.classList.add("is-visible");
      });

      card.addEventListener("pointermove", (event) => {
        const gap = 18;
        const tooltipWidth = tooltip.offsetWidth;
        const tooltipHeight = tooltip.offsetHeight;
        const left = Math.min(
          event.clientX + gap,
          window.innerWidth - tooltipWidth - 12,
        );
        const top = Math.min(
          event.clientY + gap,
          window.innerHeight - tooltipHeight - 12,
        );

        tooltip.style.transform = `translate3d(${Math.max(12, left)}px, ${Math.max(12, top)}px, 0)`;
      });

      card.addEventListener("pointerleave", () => {
        tooltip.setAttribute("aria-hidden", "true");
        tooltip.classList.remove("is-visible");
      });
    });
  }
</script>

<style>
  :global(body) {
    background:
      radial-gradient(circle at 12% 8%, rgba(103, 155, 151, 0.08), transparent 25rem),
      #f7f3ec;
  }

  .quests-shell {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 6.5rem) 0 clamp(4rem, 8vw, 7rem);
  }

  .quests-intro {
    max-width: 740px;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  .quests-intro h1 {
    margin: 0;
    color: #101b2a;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(3.5rem, 8vw, 6.8rem);
    font-weight: 700;
    letter-spacing: -0.055em;
    line-height: 0.94;
  }

  .intro-copy {
    max-width: 43rem;
    margin: 1.5rem 0 0;
    color: rgba(16, 27, 42, 0.68);
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .quest-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.4rem);
  }

  .quest-card {
    position: relative;
    isolation: isolate;
    display: flex;
    min-height: 360px;
    overflow: hidden;
    border: 1px solid rgba(16, 27, 42, 0.1);
    border-radius: 2rem;
    box-shadow:
      0 20px 45px rgba(16, 27, 42, 0.06),
      inset 0 1px rgba(255, 255, 255, 0.45);
    color: #101b2a;
    text-decoration: none;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .quest-card:hover {
    transform: translateY(-5px);
    border-color: rgba(66, 120, 115, 0.35);
    box-shadow:
      0 26px 60px rgba(16, 27, 42, 0.11),
      inset 0 1px rgba(255, 255, 255, 0.5);
  }

  .quest-card:focus-visible,
  .quest-card a:focus-visible {
    outline: 3px solid #66aaa3;
    outline-offset: 5px;
  }

  .external-mark {
    position: absolute;
    z-index: 5;
    top: clamp(1.15rem, 2.5vw, 1.6rem);
    right: clamp(1.15rem, 2.5vw, 1.6rem);
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1px solid currentColor;
    border-radius: 50%;
    font-size: 0.9rem;
    opacity: 0.5;
  }

  .duo-card {
    grid-column: span 7;
    background: #e5e5e5;
  }

  .duo-copy {
    position: relative;
    z-index: 3;
    width: 52%;
    align-self: flex-end;
    padding: 4rem 0 3rem clamp(1.4rem, 3vw, 2.2rem);
  }

  .duo-streak {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0 0 0.8rem;
    color: #e2472f;
  }

  #duo-streak-number {
    font-size: clamp(2.6rem, 6vw, 4.8rem);
    font-weight: 850;
    letter-spacing: -0.07em;
    line-height: 0.8;
  }

  #duo-streak-label {
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .duo-copy h2,
  .notes-copy h2,
  .github-copy h2 {
    margin: 0;
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .duo-copy > p:last-child,
  .notes-copy p,
  .github-copy p {
    margin: 0.85rem 0 0;
    font-size: 1rem;
    line-height: 1.55;
    opacity: 0.68;
  }

  .duo-avatar {
    position: absolute;
    z-index: 1;
    right: -4%;
    bottom: 0;
    width: 58%;
    height: auto;
    object-fit: contain;
    transform-origin: bottom center;
    animation: duo-float 5.5s ease-in-out infinite;
  }

  .duo-meta {
    position: absolute;
    z-index: 4;
    right: 1.3rem;
    bottom: 1.1rem;
    display: flex;
    gap: 0.35rem;
    padding: 0.45rem 0.65rem;
    border: 1px solid rgba(16, 27, 42, 0.12);
    border-radius: 999px;
    background: rgba(247, 243, 236, 0.86);
    color: #101b2a;
    font-size: 0.72rem;
    font-weight: 700;
    backdrop-filter: blur(8px);
  }

  .notes-card {
    grid-column: span 5;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1.4rem, 3vw, 2.2rem);
    background: #ffffff;
  }

  .audible-logo {
    position: absolute;
    top: clamp(2rem, 5vw, 3.4rem);
    left: clamp(1.4rem, 3vw, 2.2rem);
    width: min(62%, 15.5rem);
    height: auto;
    object-fit: contain;
  }

  .notes-copy {
    position: relative;
    z-index: 2;
    max-width: 27rem;
    padding-bottom: 3.4rem;
  }

  .card-action {
    position: absolute;
    right: clamp(1.4rem, 3vw, 2.2rem);
    bottom: clamp(1.4rem, 3vw, 2rem);
    left: clamp(1.4rem, 3vw, 2.2rem);
    font-size: 0.92rem;
    font-weight: 750;
  }

  .strava-card {
    grid-column: span 5;
    min-height: 360px;
    background: #ffffff;
  }

  .strava-embed-shell {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: #ffffff;
  }

  .strava-embed-shell :global(.strava-embed-placeholder) {
    width: 100%;
  }

  .strava-embed-shell :global(iframe) {
    width: 132% !important;
    min-width: 132% !important;
    height: 900px !important;
    border: 0 !important;
    transform: scale(0.76);
    transform-origin: top left;
  }

  .strava-overlay {
    position: absolute;
    z-index: 8;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    justify-content: flex-end;
    padding: 3.5rem 1.25rem 1.15rem;
    background: linear-gradient(transparent, rgba(255, 255, 255, 0.96) 56%);
    pointer-events: none;
  }

  .strava-overlay a {
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    background: #f35a23;
    color: #ffffff;
    font-size: 0.8rem;
    font-weight: 800;
    text-decoration: none;
    pointer-events: auto;
  }

  .github-card {
    grid-column: span 7;
    flex-direction: column;
    justify-content: flex-end;
    padding: clamp(1.4rem, 3vw, 2.2rem);
    border-color: rgba(247, 243, 236, 0.14);
    background:
      linear-gradient(rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0)),
      #101b2a;
    color: #f7f3ec;
  }

  .code-window {
    position: absolute;
    top: 2rem;
    right: 2rem;
    width: min(48%, 19rem);
    height: 8.8rem;
    padding: 1.2rem;
    border: 1px solid rgba(247, 243, 236, 0.14);
    border-radius: 1rem;
    background: rgba(4, 11, 20, 0.55);
    box-shadow: inset 0 0 40px rgba(0, 0, 0, 0.23);
  }

  .code-dots {
    display: flex;
    gap: 0.35rem;
    margin-bottom: 1rem;
  }

  .code-dots i {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: #8ec2bd;
    opacity: 0.75;
  }

  .code-line {
    display: block;
    height: 0.45rem;
    margin-top: 0.6rem;
    border-radius: 99px;
    background: #8ec2bd;
    opacity: 0.4;
    animation: code-pulse 4s ease-in-out infinite;
  }

  .line-one { width: 72%; }
  .line-two { width: 46%; animation-delay: 250ms; }
  .line-three { width: 86%; animation-delay: 500ms; }
  .line-four { width: 58%; animation-delay: 750ms; }

  .github-copy {
    max-width: 48%;
    padding-bottom: 3.5rem;
  }

  #quest-tooltip {
    position: fixed;
    z-index: 100;
    top: 0;
    left: 0;
    max-width: min(19rem, calc(100vw - 2rem));
    padding: 0.65rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0.75rem;
    background: #101b2a;
    box-shadow: 0 12px 30px rgba(16, 27, 42, 0.18);
    color: #f7f3ec;
    font-size: 0.78rem;
    line-height: 1.35;
    opacity: 0;
    pointer-events: none;
    transform: translate3d(-999px, -999px, 0);
    transition: opacity 120ms ease;
  }

  #quest-tooltip.is-visible {
    opacity: 0.96;
  }

  @keyframes duo-float {
    0%, 100% { transform: translateY(0) rotate(-0.5deg); }
    50% { transform: translateY(-7px) rotate(0.5deg); }
  }

  @keyframes code-pulse {
    0%, 100% { opacity: 0.28; transform: scaleX(0.96); transform-origin: left; }
    50% { opacity: 0.72; transform: scaleX(1); transform-origin: left; }
  }

  @media (max-width: 820px) {
    .quests-shell {
      width: min(100% - 1.25rem, 680px);
      padding-top: 3rem;
    }

    .quest-grid {
      grid-template-columns: 1fr;
    }

    .duo-card,
    .notes-card,
    .strava-card,
    .github-card {
      grid-column: 1;
    }

    .quest-card {
      min-height: 390px;
      border-radius: 1.55rem;
    }

    .duo-copy {
      width: 57%;
      padding-bottom: 3.5rem;
    }

    .duo-avatar {
      right: -10%;
      width: 66%;
    }

    .github-copy {
      max-width: 58%;
    }

    .strava-embed-shell :global(iframe) {
      width: 100% !important;
      min-width: 100% !important;
      transform: none;
    }
  }

  @media (max-width: 520px) {
    .quests-shell {
      width: min(100% - 1rem, 500px);
    }

    .quest-card {
      min-height: 360px;
    }

    .duo-copy {
      width: 62%;
    }

    .duo-avatar {
      right: -18%;
      width: 73%;
      height: auto;
    }

    .duo-meta {
      right: 0.9rem;
      bottom: 0.9rem;
    }

    .code-window {
      right: 1.2rem;
      width: 46%;
    }

    .github-copy {
      max-width: 61%;
    }

    .notes-copy p,
    .github-copy p,
    .duo-copy > p:last-child {
      font-size: 0.94rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .quest-card,
    .duo-avatar,
    .code-line,
    #quest-tooltip {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
