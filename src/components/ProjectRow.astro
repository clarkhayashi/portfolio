---
import StatusLabel from "./StatusLabel.astro";

interface Props {
  number: string;
  title: string;
  description: string;
  tags: string[];
  lane?: string;
  proof?: string;
  href?: string;
  external?: boolean;
  statusLabel: string;
  statusType?: "progress" | "building" | "private";
}

const { number, title, description, tags, lane, proof, href, external, statusLabel, statusType } =
  Astro.props;
const Tag = href ? "a" : "div";
---

<Tag
  {...href ? { href } : {}}
  {...external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
  class="group block border-t border-ink/10 py-9 md:py-11"
>
  <div class="grid gap-3 md:grid-cols-[3.5rem_1fr_auto] md:gap-6">
    <span class="select-none font-serif text-3xl font-bold leading-none text-bark/25 md:text-4xl">{number}</span>
    <div>
      {
        lane && (
          <p class="mb-1.5 text-xs font-medium uppercase tracking-[0.14em] text-bark/70">
            {lane}
          </p>
        )
      }
      <h3 class="font-serif text-2xl font-bold leading-snug tracking-tight md:text-[1.7rem]">
        <span class:list={[href && "transition-colors group-hover:text-teal"]}>{title}</span>
        {
          href && (
            <span
              class="ml-2 inline-block -translate-x-1 text-teal opacity-0 transition group-hover:translate-x-0 group-hover:opacity-100"
              aria-hidden="true"
            >
              →
            </span>
          )
        }
      </h3>
      <p class="mt-2 max-w-[58ch] leading-relaxed text-ink/70">
        {description}
      </p>
      {
        proof && (
          <p class="mt-2.5 text-sm font-medium text-bark">
            {proof}
          </p>
        )
      }
      <p class="mt-2 text-sm text-ink/45">{tags.join(" · ")}</p>
    </div>
    <div class="md:pt-1.5">
      <StatusLabel label={statusLabel} type={statusType} />
    </div>
  </div>
</Tag>
