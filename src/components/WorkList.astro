---
import ProjectRow from "./ProjectRow.astro";
import { projects as allProjects } from "../data/projects";
import type { Project } from "../data/projects";

interface Props {
  items?: Project[];
  startAt?: number;
}

const { items = allProjects, startAt = 1 } = Astro.props;
---

<div class="border-b border-ink/10">
  {
    items.map((p, i) => (
      <ProjectRow
        number={String(i + startAt).padStart(2, "0")}
        title={p.title}
        description={p.description}
        tags={p.tags}
        lane={p.lane}
        proof={p.proof}
        href={p.href}
        external={p.external}
        statusLabel={p.statusLabel}
        statusType={p.statusType}
      />
    ))
  }
</div>
