---
const current = Astro.url.pathname;
const links = [
  { href: "/work", label: "Work" },
  { href: "/journey", label: "Journey" },
  { href: "/about", label: "About" },
  { href: "/resume.pdf", label: "Resume" },
];
---

<header
  class="mx-auto flex max-w-[1000px] flex-col items-stretch gap-4 px-6 py-6 sm:flex-row sm:items-center sm:justify-between md:py-8"
>
  <a
    href="/"
    aria-label="Clark Hayashi, home"
    class="group flex w-fit items-center gap-3"
  >
    <img
      src="/favicon.svg"
      alt=""
      width="52"
      height="52"
      class="h-11 w-11 shrink-0 transition-transform duration-200 group-hover:-rotate-3 md:h-[3.25rem] md:w-[3.25rem]"
    />
    <span
      class="font-serif text-[2.35rem] font-bold leading-none tracking-[-0.025em] text-ink transition-colors group-hover:text-teal-deep md:text-[3rem]"
    >
      Clark Hayashi
    </span>
  </a>
  <nav
    aria-label="Main"
    class="flex w-full justify-between gap-4 text-sm font-medium sm:w-auto sm:justify-start sm:gap-5 md:gap-8"
  >
    {
      links.map((l) => (
        <a
          href={l.href}
          class:list={[
            "relative py-1 transition-colors after:absolute after:inset-x-0 after:-bottom-0.5 after:h-px after:origin-left after:scale-x-0 after:bg-teal after:transition-transform hover:text-teal-deep hover:after:scale-x-100",
            current.startsWith(l.href) && l.href !== "/resume.pdf"
              ? "text-teal-deep after:scale-x-100"
              : "text-ink/80",
          ]}
        >
          {l.label}
        </a>
      ))
    }
  </nav>
</header>
