---
import { journey } from "../data/journey";

const stops = journey.map(({ place, lon, lat, years, landmark, glyph }) => ({
  place,
  lon,
  lat,
  years,
  landmark,
  glyph,
}));

const uniqueStops = stops.filter(
  (stop, index, all) => all.findIndex((candidate) => candidate.place === stop.place) === index,
);
---

<section
  id="journey-home"
  class="border-y border-ink/10 bg-teal/[0.055]"
  data-stops={JSON.stringify(stops)}
  tabindex="0"
  aria-label="Clark's journey across Honolulu, Seattle, Tokyo, and Sansepolcro"
  aria-roledescription="carousel"
>
  <div class="mx-auto max-w-[1080px] px-6 py-14 md:py-20">
    <p class="text-xs font-medium uppercase tracking-[0.16em] text-teal-deep">The Journey</p>
    <h2 class="mt-3 max-w-[23ch] font-serif text-3xl font-bold leading-tight tracking-tight md:text-[2.6rem]">
      Rooted in Hawai‘i, built in Seattle, and shaped by Tokyo and Tuscany
    </h2>
    <p class="mt-4 max-w-[58ch] leading-relaxed text-ink/70">
      The work grew from these places. Move through the route, then follow it into the proof.
    </p>

    <div class="mt-10 grid items-center gap-10 lg:grid-cols-[minmax(340px,460px)_1fr] lg:gap-14">
      <div id="journey-globe-column">
        <div id="home-globe-box" class="relative mx-auto aspect-square w-full max-w-[460px]">
          <canvas
            id="home-globe"
            class="h-full w-full cursor-grab active:cursor-grabbing"
            aria-hidden="true"
          ></canvas>

          <div id="journey-map-markers" class="absolute inset-0" aria-label="Journey landmarks">
            {uniqueStops.map((stop) => (
              <button
                type="button"
                class="journey-map-marker"
                data-place={stop.place}
                aria-label={`View ${stop.place}: ${stop.landmark}`}
                hidden
              >
                <span class="journey-marker-dot" aria-hidden="true"></span>
                <span class="journey-marker-bubble" aria-hidden="true">
                  <svg viewBox="0 0 28 28">
                    {stop.glyph === "wave" && <path d="M2 10c3.4-3.2 6.8-3.2 10.2 0s6.8 3.2 10.2 0 3.4-3.2 3.6-3.2M2 17c3.4-3.2 6.8-3.2 10.2 0s6.8 3.2 10.2 0 3.4-3.2 3.6-3.2" />}
                    {stop.glyph === "needle" && <path d="M14 2v24M9 8h10M11 8 9 26M17 8l2 18M7 18h14M10 26h8" />}
                    {stop.glyph === "tower" && <path d="m14 2-6 24m6-24 6 24M10.5 10h7M9 17h10M7 26h14" />}
                    {stop.glyph === "hill" && <path d="M2 23c4-5 7-5 11-1 4-5 8-5 13 1M12 21V9h7v12M14 9V5h3v4M14 13h3" />}
                  </svg>
                  <span>
                    <strong>{stop.place}</strong>
                    <small>{stop.landmark}</small>
                  </span>
                </span>
              </button>
            ))}
          </div>

          <div class="journey-zoom" role="group" aria-label="Globe zoom controls">
            <button id="journey-zoom-in" type="button" aria-label="Zoom in on the globe" aria-controls="home-globe">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
            </button>
            <button id="journey-zoom-out" type="button" aria-label="Zoom out from the globe" aria-controls="home-globe">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14" /></svg>
            </button>
          </div>
        </div>

        <div class="journey-step-controls mt-4 flex items-center justify-center gap-4">
          <button id="journey-prev" type="button" aria-label="Previous place">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 5-7 7 7 7" /></svg>
          </button>
          <span id="journey-current" class="min-w-28 text-center text-xs font-medium uppercase tracking-[0.12em] text-bark" aria-live="polite">
            {stops[0].place}
          </span>
          <button id="journey-next" type="button" aria-label="Next place">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path id="journey-next-path" d="m9 5 7 7-7 7" /></svg>
          </button>
        </div>

        <div
          id="journey-chips"
          class="mt-3 flex flex-wrap justify-center gap-x-4 gap-y-1"
          role="tablist"
          aria-label="Journey locations"
        ></div>
        <p class="mt-2 text-center text-xs text-ink/50">Drag · select a landmark · zoom with + and −</p>
      </div>

      <div class="flex min-h-[470px] flex-col justify-center" aria-live="polite">
        {journey.map((stop, index) => (
          <article class="journey-card" data-index={index} hidden={index !== 0}>
            <p class="text-xs font-medium uppercase tracking-[0.16em] text-bark">{stop.place}</p>
            <h3 class="mt-2 font-serif text-3xl font-bold tracking-tight">{stop.title}</h3>
            <p class="mt-1 font-serif text-lg font-semibold italic text-teal-deep">{stop.years}</p>
            <p class="mt-4 max-w-[54ch] leading-relaxed text-ink/75">{stop.story}</p>
            {stop.photo && (
              <figure class="journey-photo mt-6">
                <img
                  src={stop.photo.src}
                  alt={stop.photo.alt}
                  width="960"
                  height="600"
                  loading={index === 0 ? "eager" : "lazy"}
                />
              </figure>
            )}
            <p class="mt-5 flex flex-wrap gap-x-5 gap-y-2">
              {stop.links?.map((link) => (
                <a
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                  class="text-sm font-medium text-teal-deep transition-colors hover:text-ink"
                >
                  {link.label} →
                </a>
              ))}
              {index === journey.length - 1 && (
                <a href="#selected-work" class="text-sm font-medium text-teal-deep transition-colors hover:text-ink">
                  See selected work ↓
                </a>
              )}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { geoGraticule10, geoOrthographic, geoPath } from "d3-geo";

  const region = document.getElementById("journey-home");
  const stops = JSON.parse(region.dataset.stops || "[]");
  const canvas = document.getElementById("home-globe");
  const box = document.getElementById("home-globe-box");
  const ctx = canvas.getContext("2d");
  const cards = [...document.querySelectorAll(".journey-card")];
  const chipsBox = document.getElementById("journey-chips");
  const prev = document.getElementById("journey-prev");
  const next = document.getElementById("journey-next");
  const nextPath = document.getElementById("journey-next-path");
  const currentPlace = document.getElementById("journey-current");
  const mapMarkers = [...document.querySelectorAll(".journey-map-marker")];
  const zoomIn = document.getElementById("journey-zoom-in");
  const zoomOut = document.getElementById("journey-zoom-out");
  const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const D = Math.PI / 180;

  const colors = {
    ocean: "#112D38",
    land: "#E9DFC9",
    coast: "rgba(247,244,239,.72)",
    grid: "rgba(247,244,239,.13)",
    route: "#9BD7D4",
    routeGlow: "rgba(155,215,212,.18)",
    rim: "rgba(247,244,239,.36)",
  };

  let size = 0;
  let radius = 0;
  let center = 0;
  let index = 0;
  let viewLon = stops[0].lon;
  let viewLat = stops[0].lat * 0.58;
  let viewZoom = 1;
  let targetZoom = 1;
  let routeProgress = 0;
  let transition = null;
  let d3 = null;
  let landGeo = null;
  let graticule = null;
  let raf = 0;
  let drag = null;

  const uniqueLocations = [];
  const locationIndex = new Map();
  stops.forEach((stop, i) => {
    if (!locationIndex.has(stop.place)) {
      locationIndex.set(stop.place, i);
      uniqueLocations.push(stop);
    }
  });

  function resize() {
    const rect = box.getBoundingClientRect();
    size = Math.min(rect.width, rect.height || rect.width);
    const dpr = Math.min(devicePixelRatio || 1, 2);
    canvas.width = Math.round(size * dpr);
    canvas.height = Math.round(size * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    radius = size * 0.425;
    center = size / 2;
    requestDraw();
  }

  function decodeLand(topo) {
    const transform = topo.transform;
    const arcs = topo.arcs.map((arc) => {
      let x = 0;
      let y = 0;
      return arc.map(([dx, dy]) => {
        x += dx;
        y += dy;
        return [x * transform.scale[0] + transform.translate[0], y * transform.scale[1] + transform.translate[1]];
      });
    });
    const ring = (ids) => {
      let points = [];
      for (const id of ids) {
        const arc = id < 0 ? arcs[~id].slice().reverse() : arcs[id];
        points = points.concat(points.length ? arc.slice(1) : arc);
      }
      return points;
    };
    const polygons = [];
    const geometries = topo.objects.land.geometries || [topo.objects.land];
    for (const geometry of geometries) {
      if (geometry.type === "Polygon") polygons.push(geometry.arcs.map(ring));
      if (geometry.type === "MultiPolygon") {
        for (const polygon of geometry.arcs) polygons.push(polygon.map(ring));
      }
    }
    return { type: "MultiPolygon", coordinates: polygons };
  }

  fetch("https://cdn.jsdelivr.net/npm/world-atlas@2/land-110m.json")
    .then((response) => response.json())
    .then((topo) => {
      d3 = { geoGraticule10, geoOrthographic, geoPath };
      landGeo = decodeLand(topo);
      graticule = d3.geoGraticule10();
      box.classList.add("map-ready");
      requestDraw();
    })
    .catch(() => box.classList.add("map-fallback"));

  uniqueLocations.forEach((stop) => {
    const button = document.createElement("button");
    button.type = "button";
    button.textContent = stop.place;
    button.setAttribute("role", "tab");
    button.setAttribute("aria-label", `Jump to ${stop.place}`);
    button.dataset.place = stop.place;
    button.className = "px-1 py-2 text-[0.69rem] font-medium uppercase tracking-[0.12em]";
    button.onclick = () => go(locationIndex.get(stop.place));
    chipsBox.appendChild(button);
  });
  const chips = [...chipsBox.children];
  mapMarkers.forEach((button) => {
    button.onclick = () => go(locationIndex.get(button.dataset.place));
  });

  function paint() {
    cards.forEach((card, i) => (card.hidden = i !== index));
    chips.forEach((chip) => {
      const selected = chip.dataset.place === stops[index].place;
      chip.style.color = selected ? "#8A1538" : "rgba(28,28,28,.62)";
      chip.setAttribute("aria-selected", selected ? "true" : "false");
    });
    mapMarkers.forEach((marker) => {
      marker.setAttribute("aria-pressed", marker.dataset.place === stops[index].place ? "true" : "false");
    });
    currentPlace.textContent = stops[index].place;
    prev.disabled = index === 0;
    const last = index === stops.length - 1;
    next.setAttribute("aria-label", last ? "Continue to selected work" : "Next place");
    nextPath.setAttribute("d", last ? "M5 9l7 7 7-7" : "m9 5 7 7-7 7");
  }

  function shortestAngle(from, to, amount) {
    const delta = ((to - from + 540) % 360) - 180;
    return from + delta * amount;
  }

  function smoothstep(t) {
    const x = Math.max(0, Math.min(1, t));
    return x * x * (3 - 2 * x);
  }

  function go(nextIndex) {
    const bounded = Math.max(0, Math.min(stops.length - 1, nextIndex));
    if (bounded === index) return;
    index = bounded;
    if (reduced) {
      viewLon = stops[index].lon;
      viewLat = stops[index].lat * 0.58;
      viewZoom = targetZoom;
      routeProgress = 1;
      transition = null;
    } else {
      transition = {
        started: performance.now(),
        duration: 1050,
        fromLon: viewLon,
        fromLat: viewLat,
        fromZoom: viewZoom,
        toLon: stops[index].lon,
        toLat: stops[index].lat * 0.58,
      };
      routeProgress = 0;
    }
    paint();
    requestDraw();
  }

  prev.onclick = () => go(index - 1);
  next.onclick = () => {
    if (index === stops.length - 1) {
      document.getElementById("selected-work").scrollIntoView({ behavior: reduced ? "auto" : "smooth" });
      return;
    }
    go(index + 1);
  };

  region.addEventListener("keydown", (event) => {
    if (event.key === "ArrowRight") {
      event.preventDefault();
      go(index + 1);
    }
    if (event.key === "ArrowLeft") {
      event.preventDefault();
      go(index - 1);
    }
  });

  function setZoom(value) {
    targetZoom = Math.max(0.86, Math.min(1.2, value));
    if (transition) transition.fromZoom = viewZoom;
    zoomIn.disabled = targetZoom >= 1.19;
    zoomOut.disabled = targetZoom <= 0.87;
    requestDraw();
  }
  zoomIn.onclick = () => setZoom(targetZoom + 0.1);
  zoomOut.onclick = () => setZoom(targetZoom - 0.1);

  function projectPoint(lon, lat) {
    const lambda = lon * D;
    const phi = lat * D;
    const lambda0 = viewLon * D;
    const phi0 = viewLat * D;
    const cosc = Math.sin(phi0) * Math.sin(phi) + Math.cos(phi0) * Math.cos(phi) * Math.cos(lambda - lambda0);
    const scale = radius * viewZoom;
    return {
      x: center + scale * Math.cos(phi) * Math.sin(lambda - lambda0),
      y: center - scale * (Math.cos(phi0) * Math.sin(phi) - Math.sin(phi0) * Math.cos(phi) * Math.cos(lambda - lambda0)),
      visible: cosc > 0,
    };
  }

  function updateMapMarkers() {
    const bubbleHalf = size < 380 ? 84 : 94;
    mapMarkers.forEach((marker) => {
      const stop = uniqueLocations.find((candidate) => candidate.place === marker.dataset.place);
      if (!stop) return;
      const point = projectPoint(stop.lon, stop.lat);
      marker.hidden = !point.visible;
      if (!point.visible) return;
      const bubbleCenter = Math.max(bubbleHalf, Math.min(size - bubbleHalf, point.x));
      marker.style.left = `${point.x}px`;
      marker.style.top = `${point.y}px`;
      marker.style.setProperty("--bubble-shift", `${bubbleCenter - point.x}px`);
      marker.dataset.active = stop.place === stops[index].place ? "true" : "false";
    });
  }

  function slerp(a, b, t) {
    const vector = (stop) => [
      Math.cos(stop.lat * D) * Math.cos(stop.lon * D),
      Math.cos(stop.lat * D) * Math.sin(stop.lon * D),
      Math.sin(stop.lat * D),
    ];
    const A = vector(a);
    const B = vector(b);
    const dot = Math.max(-1, Math.min(1, A[0] * B[0] + A[1] * B[1] + A[2] * B[2]));
    const omega = Math.acos(dot);
    if (omega < 1e-6) return a;
    const aWeight = Math.sin((1 - t) * omega) / Math.sin(omega);
    const bWeight = Math.sin(t * omega) / Math.sin(omega);
    const point = [
      A[0] * aWeight + B[0] * bWeight,
      A[1] * aWeight + B[1] * bWeight,
      A[2] * aWeight + B[2] * bWeight,
    ];
    return {
      lon: Math.atan2(point[1], point[0]) / D,
      lat: Math.asin(Math.max(-1, Math.min(1, point[2]))) / D,
    };
  }

  canvas.addEventListener("pointerdown", (event) => {
    canvas.setPointerCapture?.(event.pointerId);
    transition = null;
    drag = {
      id: event.pointerId,
      x: event.clientX,
      y: event.clientY,
      lon: viewLon,
      lat: viewLat,
      moved: false,
    };
  });

  canvas.addEventListener("pointermove", (event) => {
    if (!drag || drag.id !== event.pointerId) return;
    const dx = event.clientX - drag.x;
    const dy = event.clientY - drag.y;
    if (Math.hypot(dx, dy) > 5) drag.moved = true;
    if (!drag.moved) return;
    viewLon = drag.lon - dx * 0.34;
    viewLat = Math.max(-74, Math.min(74, drag.lat + dy * 0.24));
    routeProgress = 1;
    requestDraw();
  });

  function endDrag(event) {
    if (!drag || drag.id !== event.pointerId) return;
    const wasMoved = drag.moved;
    drag = null;
    if (wasMoved) return;
    const rect = canvas.getBoundingClientRect();
    const x = event.clientX - rect.left;
    const y = event.clientY - rect.top;
    for (const stop of uniqueLocations) {
      const point = projectPoint(stop.lon, stop.lat);
      if (point.visible && Math.hypot(point.x - x, point.y - y) < 20) {
        go(locationIndex.get(stop.place));
        return;
      }
    }
    go((index + 1) % stops.length);
  }
  canvas.addEventListener("pointerup", endDrag);
  canvas.addEventListener("pointercancel", () => (drag = null));

  function updateCamera(now) {
    let moving = false;
    if (transition) {
      const elapsed = (now - transition.started) / transition.duration;
      const t = Math.max(0, Math.min(1, elapsed));
      const eased = t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      viewLon = shortestAngle(transition.fromLon, transition.toLon, eased);
      viewLat = transition.fromLat + (transition.toLat - transition.fromLat) * eased;
      const travelPullback = Math.sin(Math.PI * t) * 0.11;
      viewZoom = transition.fromZoom + (targetZoom - transition.fromZoom) * eased - travelPullback;
      routeProgress = smoothstep((t - 0.36) / 0.64);
      moving = t < 1;
      if (!moving) {
        viewLon = transition.toLon;
        viewLat = transition.toLat;
        viewZoom = targetZoom;
        routeProgress = 1;
        transition = null;
      }
    } else if (Math.abs(viewZoom - targetZoom) > 0.001) {
      viewZoom += (targetZoom - viewZoom) * (reduced ? 1 : 0.16);
      moving = !reduced;
    }
    return moving;
  }

  function drawFallback() {
    ctx.beginPath();
    ctx.arc(center, center, radius * viewZoom, 0, Math.PI * 2);
    ctx.fillStyle = colors.ocean;
    ctx.fill();
    ctx.strokeStyle = colors.rim;
    ctx.lineWidth = 1.4;
    ctx.stroke();
  }

  function drawRoute(path) {
    if (index === 0 || routeProgress <= 0) return;
    const previous = stops[index - 1];
    const active = stops[index];
    const coordinates = [];
    const steps = Math.max(2, Math.floor(72 * routeProgress));
    for (let step = 0; step <= steps; step++) {
      const point = slerp(previous, active, step / 72);
      coordinates.push([point.lon, point.lat]);
    }
    const route = { type: "LineString", coordinates };
    ctx.lineCap = "round";
    ctx.beginPath();
    path(route);
    ctx.strokeStyle = colors.routeGlow;
    ctx.lineWidth = 7;
    ctx.stroke();
    ctx.beginPath();
    path(route);
    ctx.strokeStyle = colors.route;
    ctx.lineWidth = 2.4;
    ctx.stroke();

    const head = slerp(previous, active, routeProgress);
    const projected = projectPoint(head.lon, head.lat);
    if (projected.visible) {
      ctx.beginPath();
      ctx.arc(projected.x, projected.y, 3.5, 0, Math.PI * 2);
      ctx.fillStyle = colors.route;
      ctx.fill();
    }
  }

  function render(now = performance.now()) {
    raf = 0;
    const moving = updateCamera(now);
    ctx.clearRect(0, 0, size, size);

    if (!d3 || !landGeo || !graticule) {
      drawFallback();
    } else {
      const projection = d3
        .geoOrthographic()
        .translate([center, center])
        .scale(radius * viewZoom)
        .rotate([-viewLon, -viewLat, 0])
        .clipAngle(90)
        .precision(0.45);
      const path = d3.geoPath(projection, ctx);

      ctx.beginPath();
      path({ type: "Sphere" });
      ctx.fillStyle = colors.ocean;
      ctx.fill();

      ctx.beginPath();
      path(graticule);
      ctx.strokeStyle = colors.grid;
      ctx.lineWidth = 0.7;
      ctx.stroke();

      ctx.beginPath();
      path(landGeo);
      ctx.fillStyle = colors.land;
      ctx.fill("evenodd");
      ctx.strokeStyle = colors.coast;
      ctx.lineWidth = 0.8;
      ctx.stroke();

      drawRoute(path);

      ctx.beginPath();
      path({ type: "Sphere" });
      ctx.strokeStyle = colors.rim;
      ctx.lineWidth = 1.4;
      ctx.stroke();
    }

    updateMapMarkers();

    if (moving || drag) requestDraw();
  }

  function requestDraw() {
    if (!raf) raf = requestAnimationFrame(render);
  }

  resize();
  new ResizeObserver(resize).observe(box);
  paint();
  setZoom(1);
  requestDraw();
</script>

<style>
  #home-globe-box::before {
    content: "";
    position: absolute;
    inset: 7.5%;
    border: 1px solid rgba(79, 119, 115, 0.16);
    border-radius: 999px;
    pointer-events: none;
  }

  #home-globe {
    display: block;
    touch-action: pan-y;
  }

  #journey-map-markers {
    z-index: 2;
    pointer-events: none;
  }

  .journey-map-marker {
    --bubble-shift: 0px;
    position: absolute;
    width: 34px;
    height: 34px;
    transform: translate(-50%, -50%);
    border: 0;
    background: transparent;
    color: #112d38;
    cursor: pointer;
    pointer-events: auto;
    z-index: 1;
  }

  .journey-marker-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 11px;
    height: 11px;
    transform: translate(-50%, -50%);
    border: 2px solid #f7f4ef;
    border-radius: 999px;
    background: #4f7773;
    transition: width 0.2s ease, height 0.2s ease, background-color 0.2s ease;
  }

  .journey-marker-dot::after {
    content: "";
    position: absolute;
    inset: 3px;
    border-radius: inherit;
    background: #f7f4ef;
    opacity: 0;
  }

  .journey-map-marker[data-active="true"] { z-index: 3; }
  .journey-map-marker[data-active="true"] .journey-marker-dot {
    width: 18px;
    height: 18px;
    border-color: #8a1538;
    background: #f7f4ef;
  }
  .journey-map-marker[data-active="true"] .journey-marker-dot::after { background: #8a1538; opacity: 1; }

  .journey-marker-bubble {
    position: absolute;
    left: 50%;
    top: -8px;
    width: 188px;
    transform: translate(calc(-50% + var(--bubble-shift)), calc(-100% - 8px)) scale(0.96);
    transform-origin: bottom center;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: 1px solid rgba(17, 45, 56, 0.22);
    border-radius: 14px;
    background: #f7f4ef;
    color: #112d38;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.24s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.2s;
  }

  .journey-marker-bubble::after {
    content: "";
    position: absolute;
    left: calc(50% - var(--bubble-shift));
    bottom: -5px;
    width: 9px;
    height: 9px;
    transform: translateX(-50%) rotate(45deg);
    border-right: 1px solid rgba(17, 45, 56, 0.22);
    border-bottom: 1px solid rgba(17, 45, 56, 0.22);
    background: #f7f4ef;
